<turbo-frame id="orden_de_compra_resumen">
  <% subtotal = orden_de_compra.detalle_ordenes_de_compra.sum { |d| d.costo_unitario_compra_calculado.to_d * d.cantidad.to_i } %>
  <% flete    = orden_de_compra.costo_total_flete.to_d %>
  <% total    = subtotal + flete %>
  <% count    = orden_de_compra.detalle_ordenes_de_compra.size %>

  <div class="stats stats-horizontal shadow">
    <div class="stat py-2 px-4">
      <div class="stat-title text-xs">Productos</div>
      <div class="stat-value text-lg"><%= count %></div>
    </div>
    <div class="stat py-2 px-4">
      <div class="stat-title text-xs">Subtotal</div>
      <div class="stat-value text-lg tabular-nums">C$ <%= number_with_precision(subtotal, precision: 2, delimiter: ',') %></div>
    </div>
    <div class="stat py-2 px-4">
      <div class="stat-title text-xs">Flete</div>
      <div class="stat-value text-lg tabular-nums">C$ <%= number_with_precision(flete, precision: 2, delimiter: ',') %></div>
    </div>
    <div class="stat py-2 px-4 bg-primary/10 rounded-box">
      <div class="stat-title text-xs font-bold text-primary">Total</div>
      <div class="stat-value text-lg tabular-nums text-primary">C$ <%= number_with_precision(total, precision: 2, delimiter: ',') %></div>
    </div>
  </div>
</turbo-frame>
