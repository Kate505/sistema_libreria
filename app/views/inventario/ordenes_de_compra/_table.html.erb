<table class="table table-pin-rows px-4">
  <thead>
    <tr class="bg-base-100 z-10">
      <th>ID</th>
      <th>Proveedor</th>
      <th>Fecha</th>
      <th>N° Factura</th>
      <th class="text-right">Flete</th>
      <th class="text-center">Líneas</th>
      <th class="text-right">Acciones</th>
    </tr>
  </thead>

  <tbody>
  <% ordenes_de_compra.each do |orden| %>
    <tr class="hover:bg-base-200">

      <td class="text-base-content/50 text-sm">#<%= orden.id %></td>

      <td class="font-medium">
        <span class="truncate block max-w-[160px]"><%= orden.proveedor.nombre %></span>
      </td>

      <td class="text-sm whitespace-nowrap">
        <%= orden.fecha_compra.strftime("%d/%m/%Y") %>
      </td>

      <td class="text-sm">
        <% if orden.numero_factura.present? %>
          <span class="font-mono text-xs badge badge-ghost badge-sm"><%= orden.numero_factura %></span>
        <% else %>
          <span class="text-base-content/30 italic text-xs">—</span>
        <% end %>
      </td>

      <td class="text-right tabular-nums text-sm">
        C$ <%= number_with_precision(orden.costo_total_flete, precision: 2, delimiter: ',') %>
      </td>

      <td class="text-center">
        <span class="badge badge-neutral badge-sm">
          <%= orden.detalle_ordenes_de_compra.size %>
        </span>
      </td>

      <td class="flex gap-2 justify-end">
        <%# Ver detalles %>
        <%= link_to inventario_orden_de_compra_path(orden),
                    data: { turbo_frame: "main_content", turbo_action: "advance" },
                    class: "btn btn-sm btn-ghost btn-square",
                    title: "Ver detalle" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        <% end %>

        <%# Editar %>
        <%= link_to edit_inventario_orden_de_compra_path(orden),
                    data: { turbo_frame: "orden_de_compra_form" },
                    class: "btn btn-sm btn-ghost btn-square",
                    title: "Editar" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
            <path fill="currentColor" d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456l-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
            <path fill="currentColor" fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
          </svg>
        <% end %>

        <%# Eliminar %>
        <%= link_to inventario_orden_de_compra_path(orden),
                    data: { turbo_method: :delete,
                            turbo_confirm: "¿Eliminar la Orden ##{orden.id} de #{orden.proveedor.nombre}? Se eliminarán todos sus detalles y se revertirá el stock de los productos." },
                    class: "btn btn-sm btn-ghost btn-square text-error",
                    title: "Eliminar" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14H6L5 6"/>
            <path d="M10 11v6M14 11v6"/>
            <path d="M9 6V4h6v2"/>
          </svg>
        <% end %>
      </td>

    </tr>
  <% end %>

  <% if ordenes_de_compra.empty? %>
    <tr>
      <td colspan="7" class="text-center py-12 text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-sm">No hay órdenes de compra registradas</p>
      </td>
    </tr>
  <% end %>

  </tbody>
</table>
