<%# Modal de Finalización de Orden de Abastecimiento %>
<div id="modal_finalizar_orden">
  <% if orden_de_compra.pendiente? %>
    <dialog id="dialog_finalizar_orden" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box w-full max-w-lg p-0 overflow-hidden">

        <%# Encabezado %>
        <div class="bg-success px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-success-content" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="font-bold text-lg text-success-content">Finalizar Orden de Abastecimiento</h3>
          </div>
          <button class="btn btn-ghost btn-sm btn-square text-success-content"
                  onclick="document.getElementById('dialog_finalizar_orden').close()">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <%# Resumen %>
        <% subtotal = orden_de_compra.detalle_ordenes_de_compra.sum { |d| d.costo_unitario_compra_calculado.to_d * d.cantidad.to_i } %>
        <% flete    = orden_de_compra.costo_total_flete.to_d %>
        <% total    = subtotal + flete %>
        <div class="px-6 py-4 bg-success/5 border-b border-base-200 space-y-1">
          <div class="flex items-center justify-between">
            <span class="text-sm text-base-content/60 font-medium">Proveedor</span>
            <span class="font-semibold"><%= orden_de_compra.proveedor.nombre %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-base-content/60 font-medium">Productos registrados</span>
            <span class="font-semibold"><%= orden_de_compra.detalle_ordenes_de_compra.size %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-base-content/60 font-medium">Total costo (inc. flete)</span>
            <span class="text-2xl font-bold tabular-nums text-success">
              C$ <%= number_with_precision(total, precision: 2, delimiter: ',') %>
            </span>
          </div>
        </div>

        <%# Error %>
        <% if local_assigns[:error].present? %>
          <div class="mx-6 mt-4 alert alert-error text-sm py-2">
            <span><%= error %></span>
          </div>
        <% end %>

        <%# Advertencia %>
        <div class="px-6 py-4">
          <div class="alert alert-warning text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.538-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
            <span>Al finalizar, <strong>no podrás modificar ni eliminar</strong> esta orden ni sus productos. El stock ya fue actualizado al agregar cada línea.</span>
          </div>
        </div>

        <%# Botones %>
        <%= form_with url: finalizar_inventario_orden_de_compra_path(orden_de_compra),
                      method: :patch,
                      class: "px-6 pb-6" do %>
          <div class="flex gap-3">
            <button type="button"
                    class="btn btn-ghost flex-1"
                    onclick="document.getElementById('dialog_finalizar_orden').close()">
              Cancelar
            </button>
            <button type="submit" class="btn btn-success flex-1 gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Confirmar y Finalizar
            </button>
          </div>
        <% end %>

      </div>
      <form method="dialog" class="modal-backdrop"><button>cerrar</button></form>
    </dialog>
  <% end %>
</div>
