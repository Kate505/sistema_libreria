<%= turbo_frame_tag "main_content" do %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <div class="grid grid-rows-[auto_1fr] gap-6 h-[calc(100vh-10rem)] w-full page-grid">

    <%# Encabezado con botón de volver %>
    <div class="flex items-center justify-between shrink-0 flex-wrap gap-3">
      <div class="flex items-center gap-3">
        <%= link_to inventario_ordenes_de_compra_path,
                    data: { turbo_frame: "main_content", turbo_action: "advance" },
                    class: "btn btn-ghost btn-sm btn-square" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <div>
          <h1 class="text-3xl font-bold page-title">
            Orden #<%= @orden_de_compra.id %>
            <span class="text-base-content/50 font-normal text-xl">— <%= @orden_de_compra.proveedor.nombre %></span>
          </h1>
          <p class="text-sm text-base-content/50">
            <%= @orden_de_compra.fecha_compra.strftime("%d/%m/%Y") %>
            <% if @orden_de_compra.numero_factura.present? %>
              · Factura: <span class="font-medium"><%= @orden_de_compra.numero_factura %></span>
            <% end %>
          </p>
        </div>
      </div>

      <%# Resumen totales %>
      <%= render "resumen", orden_de_compra: @orden_de_compra %>
    </div>

    <% if @orden_de_compra.finalizada? %>
      <%# ── Orden finalizada: solo tabla, ancho completo ── %>
      <div class="grid grid-cols-1 gap-4 min-h-0">
        <div class="card bg-base-100 shadow-xl flex flex-col h-full overflow-hidden">
          <div class="flex-1 overflow-y-auto table-scroll-wrapper">
            <div id="detalle_ordenes_de_compra_table">
              <%= render "inventario/detalle_ordenes_de_compra/table",
                         orden_de_compra: @orden_de_compra,
                         detalles: @detalles %>
            </div>
          </div>
        </div>
      </div>

    <% else %>
      <%# ── Orden pendiente: formulario + tabla ── %>

      <%# Mobile: button to open form modal %>
      <div class="lg:hidden -mt-4 mb-0">
        <button class="btn btn-primary btn-sm w-full" onclick="document.getElementById('mobile_detalle_modal').showModal()">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Agregar Producto
        </button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 min-h-0">

        <%# Desktop: inline form card (hidden on mobile) %>
        <div class="card bg-base-100 shadow-xl overflow-hidden flex-col h-full lg:max-h-full hidden lg:flex">
          <div class="overflow-y-auto flex-1 p-0">
            <%= render "inventario/detalle_ordenes_de_compra/form",
                       orden_de_compra: @orden_de_compra,
                       detalle: @detalle %>
          </div>
        </div>

        <%# Tabla de líneas %>
        <div class="card bg-base-100 shadow-xl lg:col-span-2 flex flex-col h-full overflow-hidden">
          <div class="flex-1 overflow-y-auto table-scroll-wrapper">
            <div id="detalle_ordenes_de_compra_table">
              <%= render "inventario/detalle_ordenes_de_compra/table",
                         orden_de_compra: @orden_de_compra,
                         detalles: @detalles %>
            </div>
          </div>
        </div>

      </div>

      <%# Mobile form modal %>
      <dialog id="mobile_detalle_modal" class="modal modal-bottom lg:hidden">
        <div class="modal-box max-h-[85vh] overflow-y-auto">
          <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button></form>
          <%= render "inventario/detalle_ordenes_de_compra/form",
                     orden_de_compra: @orden_de_compra,
                     detalle: @detalle %>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>
    <% end %>

  </div>

<% end %>
