<%= turbo_frame_tag "main_content" do %>

  <div class="grid grid-rows-[auto_auto_1fr] gap-4 h-[calc(100vh-10rem)] w-full">

    <%# Header %>
    <div class="flex items-center justify-between shrink-0 flex-wrap gap-3">
      <div>
        <h1 class="text-3xl font-bold">Consulta de Inventario</h1>
        <p class="text-base-content/50 text-sm mt-0.5">Precios, stock y condiciones de productos</p>
      </div>
    </div>

    <%# Barra de búsqueda %>
    <div class="card bg-base-100 shadow-sm shrink-0">
      <div class="card-body py-3 px-4">
        <%= form_with url: consulta_precios_inventario_productos_path,
                      method: :get,
                      data: { turbo_frame: "consulta_table_frame", turbo_action: "advance" },
                      class: "flex gap-3 items-center" do |f| %>

          <label class="input input-bordered flex items-center gap-2 flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
            </svg>
            <%= f.text_field :q,
                             value: @q,
                             placeholder: "Buscar por nombre, SKU o categoría...",
                             class: "grow",
                             autofocus: true,
                             autocomplete: "off" %>
            <% if @q.present? %>
              <%= link_to consulta_precios_inventario_productos_path,
                          data: { turbo_frame: "consulta_table_frame" },
                          class: "btn btn-ghost btn-xs btn-square",
                          title: "Limpiar búsqueda" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              <% end %>
            <% end %>
          </label>

          <%= f.submit "Buscar", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>

    <%# Tabla de resultados %>
    <div class="card bg-base-100 shadow-xl flex flex-col overflow-hidden">
      <%= turbo_frame_tag "consulta_table_frame", class: "flex flex-col overflow-hidden h-full" do %>
        <%# Contador de resultados %>
        <div class="px-4 pt-3 pb-1 shrink-0 flex items-center gap-2">
          <% count = @productos.count %>
          <span class="text-sm text-base-content/50">
            <% if @q.present? %>
              <%= count %> resultado<%= count == 1 ? "" : "s" %> para <span class="font-semibold text-base-content">"<%= @q %>"</span>
            <% else %>
              <%= count %> producto<%= count == 1 ? "" : "s" %> en total
            <% end %>
          </span>
        </div>

        <div class="overflow-y-auto flex-1">
          <%= render "consulta_precios_table", productos: @productos %>
        </div>
      <% end %>
    </div>

  </div>

<% end %>
