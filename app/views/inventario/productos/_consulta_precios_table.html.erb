<table class="table table-pin-rows px-4 w-full">
  <thead>
    <tr class="bg-base-100 z-10">
      <th class="w-8">SKU</th>
      <th>Nombre</th>
      <th>Categoría</th>
      <th class="text-right">P. Venta</th>
      <th class="text-right">P. Mayor</th>
      <th class="text-center">Descuento</th>
      <th class="text-center">Stock</th>
      <th class="text-center hidden md:table-cell">Mín.</th>
      <th class="text-center hidden md:table-cell">Máx.</th>
    </tr>
  </thead>

  <tbody>
  <% productos.each do |producto| %>
    <% stock = producto.stock_actual.to_i %>
    <% min   = producto.stock_minimo_limite.to_i %>
    <tr class="hover:bg-base-200">

      <%# SKU %>
      <td class="text-base-content/45 text-xs font-mono whitespace-nowrap">
        <%= producto.sku.presence || "—" %>
      </td>

      <%# Nombre %>
      <td class="font-medium max-w-xs">
        <span class="truncate block"><%= producto.nombre %></span>
      </td>

      <%# Categoría %>
      <td>
        <% if producto.categoria.present? %>
          <span class="badge badge-ghost badge-sm"><%= producto.categoria.nombre %></span>
        <% else %>
          <span class="text-base-content/30 text-sm italic">—</span>
        <% end %>
      </td>

      <%# Precio de venta %>
      <td class="text-right font-semibold tabular-nums whitespace-nowrap">
        C$ <%= number_with_precision(producto.precio_venta, precision: 2, delimiter: ",") %>
      </td>

      <%# Precio al mayor %>
      <td class="text-right tabular-nums whitespace-nowrap text-base-content/70">
        C$ <%= number_with_precision(producto.precio_venta_al_mayor, precision: 2, delimiter: ",") %>
      </td>

      <%# Descuento %>
      <td class="text-center">
        <% if producto.descuento? %>
          <div class="flex flex-col items-center gap-0.5">
            <span class="badge badge-info badge-sm">Sí</span>
            <span class="text-xs text-base-content/50">
              máx. <%= number_with_precision(producto.descuento_maximo, precision: 0) %>%
            </span>
          </div>
        <% else %>
          <span class="text-base-content/30 text-sm">No</span>
        <% end %>
      </td>

      <%# Stock con semáforo %>
      <td class="text-center">
        <% if stock <= 0 %>
          <span class="badge badge-error badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <%= stock %>
          </span>
        <% elsif stock <= min %>
          <span class="badge badge-warning badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12A9 9 0 113 12a9 9 0 0118 0z" />
            </svg>
            <%= stock %>
          </span>
        <% else %>
          <span class="badge badge-success badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <%= stock %>
          </span>
        <% end %>
      </td>

      <%# Stock mínimo %>
      <td class="text-center text-sm text-base-content/50 hidden md:table-cell tabular-nums">
        <%= producto.stock_minimo_limite %>
      </td>

      <%# Stock máximo %>
      <td class="text-center text-sm text-base-content/50 hidden md:table-cell tabular-nums">
        <%= producto.stock_maximo_limite %>
      </td>

    </tr>
  <% end %>

  <% if productos.empty? %>
    <tr>
      <td colspan="9" class="text-center py-16 text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <p class="text-sm">No se encontraron productos</p>
      </td>
    </tr>
  <% end %>

  </tbody>
</table>
