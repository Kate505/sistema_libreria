<turbo-frame id="producto_form">
  <%= form_with(model: producto,
                url: producto.new_record? ? inventario_productos_path : inventario_producto_path(producto),
                method: producto.new_record? ? :post : :patch,
                class: 'contents') do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">
        <%= producto.new_record? ? "Agregar nuevo producto" : "Editar producto: #{producto.nombre}" %>
      </h2>

      <%# Errores %>
      <% if producto.errors.any? %>
        <div class="alert alert-error text-sm py-2">
          <ul class="list-disc list-inside">
            <% producto.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# SKU %>
        <div class="w-full">
          <%= f.label :sku, 'SKU', class: 'label pt-0' %>
          <%= f.text_field :sku, class: 'input input-bordered w-full', placeholder: 'Ej: LIB-001', required: true %>
        </div>

        <%# Nombre %>
        <div class="w-full">
          <%= f.label :nombre, 'Nombre del Producto', class: 'label pt-0' %>
          <%= f.text_field :nombre, class: 'input input-bordered w-full', placeholder: 'Nombre del producto', required: true %>
        </div>

        <%# Categoría - Autocomplete %>
        <div class="w-full sm:col-span-2 relative"
             data-controller="autocomplete"
             data-autocomplete-url-value="<%= buscar_categoria_inventario_productos_path %>"
             data-action="click@window->autocomplete#hide">

          <%= f.label :categorias_id, 'Categoría', class: 'label pt-0' %>

          <%= f.hidden_field :categorias_id, data: { autocomplete_target: "hidden" } %>

          <div class="relative">
            <% nombre_categoria = producto.categorias_id.present? ? producto.categoria&.nombre : "" %>

            <input type="text"
                   class="input input-bordered w-full pr-10"
                   placeholder="Buscar categoría..."
                   value="<%= nombre_categoria %>"
                   data-autocomplete-target="input"
                   data-action="input->autocomplete#search"
                   autocomplete="off">

            <div data-autocomplete-target="loading" class="absolute right-3 top-3 hidden">
              <span class="loading loading-spinner loading-sm text-primary"></span>
            </div>
          </div>

          <ul data-autocomplete-target="results"
              class="menu dropdown-content bg-base-100 rounded-box z-[50] w-full p-2 shadow-lg absolute top-full mt-1 border border-base-200 hidden max-h-60 overflow-y-auto">
          </ul>
        </div>

        <%# Precio de Venta %>
        <div class="w-full">
          <%= f.label :precio_venta, 'Precio de Venta', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :precio_venta, step: '0.01', min: 0, class: 'grow', placeholder: '0.00', required: true %>
          </label>
        </div>

        <%# Precio de Venta al Mayor %>
        <div class="w-full">
          <%= f.label :precio_venta_al_mayor, 'Precio al Mayor', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :precio_venta_al_mayor, step: '0.01', min: 0, class: 'grow', placeholder: '0.00', required: true %>
          </label>
        </div>

        <%# === SECCIÓN: STOCK === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Control de Stock
          </div>
        </div>

        <%# Stock Actual %>
        <div class="w-full">
          <%= f.label :stock_actual, 'Stock Actual', class: 'label pt-0' %>
          <%= f.number_field :stock_actual, min: 0, class: 'input input-bordered w-full', placeholder: '0' %>
        </div>

        <%# Stock Mínimo %>
        <div class="w-full">
          <%= f.label :stock_minimo_limite, 'Stock Mínimo', class: 'label pt-0' %>
          <%= f.number_field :stock_minimo_limite, min: 1, class: 'input input-bordered w-full', placeholder: '1' %>
        </div>

        <%# Stock Máximo %>
        <div class="w-full">
          <%= f.label :stock_maximo_limite, 'Stock Máximo', class: 'label pt-0' %>
          <%= f.number_field :stock_maximo_limite, min: 1, class: 'input input-bordered w-full', placeholder: '1' %>
        </div>

        <%# === SECCIÓN: DESCUENTO === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Descuento
          </div>
        </div>

        <%# Descuento toggle %>
        <div class="w-full">
          <%= f.label :descuento, class: 'cursor-pointer label flex flex-col items-start gap-1 pt-0' do %>
            <span class="label-text font-medium">¿Permite descuento?</span>
            <%= f.check_box :descuento, class: 'toggle toggle-primary' %>
          <% end %>
        </div>

        <%# Descuento Máximo (%) %>
        <div class="w-full">
          <%= f.label :descuento_maximo, 'Descuento Máximo (%)', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <%= f.number_field :descuento_maximo, min: 0, max: 100, class: 'grow', placeholder: '0' %>
            <span class="text-base-content/60 text-sm font-semibold">%</span>
          </label>
        </div>

        <%# Botones de acción %>
        <div class="card-actions justify-end sm:col-span-2 col-span-full mt-4 pt-4 border-t border-base-200">
          <%= save_button(f) %>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
