<table class="table table-pin-rows px-4">
  <thead>
  <tr class="bg-base-100 z-10">
    <th>ID</th>
    <th>Nombre</th>
    <th>Categoría</th>
    <th class="text-right">Precio Venta</th>
    <th>Stock</th>
    <th class="text-right">Acciones</th>
  </tr>
  </thead>

  <tbody>
  <% productos.each do |producto| %>
    <tr class="hover:bg-base-200">
      <td class="text-base-content/50 text-sm"><%= producto.id %></td>

      <td class="font-medium max-w-xs">
        <span class="truncate block"><%= producto.nombre %></span>
      </td>

      <td>
        <% if producto.categoria.present? %>
          <span class="badge badge-ghost badge-sm"><%= producto.categoria.nombre %></span>
        <% else %>
          <span class="text-base-content/30 text-sm italic">—</span>
        <% end %>
      </td>

      <td class="text-right font-semibold tabular-nums">
        C$ <%= number_with_precision(producto.precio_venta, precision: 2, delimiter: ',') %>
      </td>

      <td>
        <% stock = producto.stock_actual.to_i %>
        <% min = producto.stock_minimo_limite.to_i %>
        <% if stock <= 0 %>
          <span class="badge badge-error badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <%= stock %>
          </span>
        <% elsif stock <= min %>
          <span class="badge badge-warning badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12A9 9 0 113 12a9 9 0 0118 0z" />
            </svg>
            <%= stock %>
          </span>
        <% else %>
          <span class="badge badge-success badge-sm gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <%= stock %>
          </span>
        <% end %>
      </td>

      <td class="flex gap-2 justify-end">
        <%= link_to edit_inventario_producto_path(producto),
                    data: { turbo_frame: "producto_form" },
                    class: "btn btn-sm btn-ghost btn-square",
                    title: "Editar" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
            <path fill="currentColor" d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456l-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
            <path fill="currentColor" fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
          </svg>
        <% end %>

        <%= link_to inventario_producto_path(producto),
                    data: { turbo_method: :delete, turbo_confirm: "¿Eliminar el producto \"#{producto.nombre}\"? Esta acción no se puede deshacer." },
                    class: "btn btn-sm btn-ghost btn-square text-error",
                    title: "Eliminar" do %>
          <% inline_svg "remove.svg" %>
        <% end %>
      </td>
    </tr>
  <% end %>

  <% if productos.empty? %>
    <tr>
      <td colspan="7" class="text-center py-12 text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <p class="text-sm">No hay productos registrados</p>
      </td>
    </tr>
  <% end %>

  </tbody>
</table>
