<turbo-frame id="detalle_orden_form">
  <%= form_with(model: [orden_de_compra, detalle],
                url: inventario_orden_de_compra_detalle_ordenes_de_compra_path(orden_de_compra),
                method: :post,
                class: 'contents') do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">Agregar Producto</h2>

      <%# Errores %>
      <% if detalle.errors.any? %>
        <div class="alert alert-error text-sm py-2">
          <ul class="list-disc list-inside">
            <% detalle.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 gap-4">

        <%# Producto - Autocomplete %>
        <div class="w-full relative"
             data-controller="autocomplete"
             data-autocomplete-url-value="<%= buscar_producto_inventario_ordenes_de_compra_path %>"
             data-action="click@window->autocomplete#hide">

          <%= f.label :producto_id, 'Producto', class: 'label pt-0' %>
          <%= f.hidden_field :producto_id, data: { autocomplete_target: "hidden" } %>

          <div class="relative">
            <% nombre_producto = detalle.producto_id.present? ? detalle.producto&.nombre : "" %>
            <input type="text"
                   class="input input-bordered w-full pr-10"
                   placeholder="Buscar por nombre o SKU..."
                   value="<%= nombre_producto %>"
                   data-autocomplete-target="input"
                   data-action="input->autocomplete#search"
                   autocomplete="off">

            <div data-autocomplete-target="loading" class="absolute right-3 top-3 hidden">
              <span class="loading loading-spinner loading-sm text-primary"></span>
            </div>
          </div>

          <ul data-autocomplete-target="results"
              class="menu dropdown-content bg-base-100 rounded-box z-[50] w-full p-2 shadow-lg absolute top-full mt-1 border border-base-200 hidden max-h-60 overflow-y-auto">
          </ul>
        </div>

        <%# Cantidad %>
        <div class="w-full">
          <%= f.label :cantidad, 'Cantidad', class: 'label pt-0' %>
          <%= f.number_field :cantidad,
                             min: 1,
                             step: 1,
                             class: 'input input-bordered w-full',
                             placeholder: '1',
                             required: true %>
        </div>

        <%# Sección Precios %>
        <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
          Costos
        </div>

        <%# Precio Unitario de Compra %>
        <div class="w-full">
          <%= f.label :precio_unitario_compra, 'Precio Unitario Compra', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :precio_unitario_compra,
                               step: '0.01', min: 0,
                               class: 'grow',
                               placeholder: '0.00',
                               required: true %>
          </label>
        </div>

        <%# Costo Unitario Calculado (con flete) %>
        <div class="w-full">
          <%= f.label :costo_unitario_compra_calculado, 'Costo Unitario Calculado', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :costo_unitario_compra_calculado,
                               step: '0.01', min: 0,
                               class: 'grow',
                               placeholder: '0.00 (incluye flete si aplica)',
                               required: true %>
          </label>
          <p class="text-xs text-base-content/40 mt-1">
            Debe ser ≥ precio de compra. Incluye flete prorrateado si aplica.
          </p>
        </div>

        <%# Acción %>
        <div class="card-actions justify-end mt-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Agregar Producto
          </button>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
