<%= turbo_frame_tag "main_content" do %>
  <%= turbo_stream_from "proveedores" %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <div class="grid grid-rows-[auto_1fr] gap-6 h-[calc(100vh-10rem)] w-full page-grid">

    <div class="flex items-center justify-between shrink-0 flex-wrap gap-3">
      <h1 class="text-3xl font-bold page-title">Proveedores</h1>
      <button class="btn btn-primary btn-sm lg:hidden" onclick="document.getElementById('mobile_form_modal').showModal()">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nuevo Proveedor
      </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 min-h-0">

      <div class="card bg-base-100 shadow-xl overflow-hidden flex-col h-full lg:max-h-full hidden lg:flex">
        <div class="overflow-y-auto flex-1 p-0">
          <%= render "form", proveedor: @proveedor %>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl lg:col-span-2 flex flex-col h-full overflow-hidden">

        <div class="px-4 pt-4 pb-2 border-b border-base-200 shrink-0">
          <%= form_with url: catalogos_proveedores_path, method: :get,
                        data: { turbo_frame: "main_content", turbo_action: "advance" },
                        class: "flex items-end gap-3 filter-bar" do %>
            <div class="flex-1">
              <input type="text" name="q" value="<%= params[:q] %>" placeholder="Buscar por nombre, teléfono, dirección..."
                     class="input input-bordered input-sm w-full" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Buscar
            </button>
            <% if params[:q].present? %>
              <%= link_to catalogos_proveedores_path,
                          data: { turbo_frame: "main_content", turbo_action: "advance" },
                          class: "btn btn-ghost btn-sm" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                Limpiar
              <% end %>
            <% end %>
          <% end %>
        </div>

        <div class="flex-1 overflow-y-auto table-scroll-wrapper" id="proveedores_table_container">
          <div id="proveedores_table" class="h-full">
            <%= render "table", proveedores: @proveedores %>
          </div>
        </div>

        <% if @proveedores.respond_to?(:total_pages) && @proveedores.total_pages > 1 %>
          <div class="border-t border-base-200 p-3 shrink-0 flex justify-center">
            <%= paginate @proveedores, theme: 'twitter-bootstrap-4', window: 2,
                         params: { q: params[:q] } %>
          </div>
        <% end %>

      </div>

    </div>

  </div>

  <dialog id="mobile_form_modal" class="modal modal-bottom lg:hidden">
    <div class="modal-box max-h-[85vh] overflow-y-auto">
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button></form>
      <%= render "form", proveedor: @proveedor %>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

<% end %>
