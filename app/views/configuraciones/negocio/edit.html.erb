<%= turbo_frame_tag "main_content" do %>
  <div class="container mx-auto max-w-3xl p-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold">Configuración de Negocio</h1>
      <p class="text-base-content/60 text-sm mt-1">
        Define los parámetros globales de margen de ganancia y alertas.
      </p>
    </div>

    <div class="card bg-base-100 shadow-md">
      <div class="card-body">

        <% if flash[:notice] %>
          <div class="alert alert-success mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <%= flash[:notice] %>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="alert alert-error mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <%= flash[:alert] %>
          </div>
        <% end %>

        <%= form_with model: @configuracion,
                      url: configuraciones_negocio_path,
                      method: :patch,
                      class: "space-y-6" do |f| %>

          <% if @configuracion.errors.any? %>
            <div class="alert alert-error text-sm py-2">
              <ul class="list-disc list-inside">
                <% @configuracion.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%# Margen de Ganancia Meta %>
          <div>
            <label class="label font-semibold">
              % Ganancia Neta Meta
            </label>
            <label class="input input-bordered flex items-center gap-2">
              <%= f.number_field :margen_ganancia_meta,
                                 step: 1, min: 1, max: 99,
                                 class: "grow",
                                 placeholder: "40",
                                 id: "configuracion_negocio_margen_ganancia_meta",
                                 value: (@configuracion.margen_ganancia_meta.to_d * 100).round(0).to_i %>
              <span class="text-base-content/60 font-semibold">%</span>
            </label>
            <p class="text-xs text-base-content/50 mt-1">
              Porcentaje de la ganancia neta deseada. Recomendado: 40%.
            </p>
          </div>

          <%# Umbral de alerta %>
          <div>
            <label class="label font-semibold">
              Umbral de Alerta de Margen Mínimo
            </label>
            <label class="input input-bordered flex items-center gap-2">
              <%= f.number_field :margen_alerta_minimo,
                                 step: 1, min: 1, max: 99,
                                 class: "grow",
                                 placeholder: "35",
                                 id: "configuracion_negocio_margen_alerta_minimo",
                                 value: (@configuracion.margen_alerta_minimo.to_d * 100).round(0).to_i %>
              <span class="text-base-content/60 font-semibold">%</span>
            </label>
            <p class="text-xs text-base-content/50 mt-1">
              Si el margen estimado de un producto cae debajo de este valor, se muestra una alerta.
            </p>
          </div>

          <div class="card-actions justify-end border-t border-base-200 pt-4">
            <%= f.submit "Guardar Configuración", class: "btn btn-primary" %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
<% end %>
