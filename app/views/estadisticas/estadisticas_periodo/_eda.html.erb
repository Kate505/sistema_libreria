<%# ── EDA: Análisis Exploratorio de Datos ──────────────────────────────── %>
<div class="card bg-base-100 shadow-sm border border-base-200 mb-4">
  <div class="card-body p-4">
    <h2 class="card-title text-base">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      EDA — Análisis Exploratorio de Datos
      <span class="badge badge-accent badge-sm font-normal">Ingresos por venta</span>
    </h2>

    <% if @eda %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-3">

        <%# Estadísticas descriptivas %>
        <div>
          <h3 class="text-sm font-semibold text-base-content/70 mb-2 uppercase tracking-wide">Estadísticas Descriptivas</h3>
          <div class="overflow-x-auto">
            <table class="table table-sm border border-base-200 rounded-lg">
              <thead>
                <tr class="bg-base-200">
                  <th class="text-xs">Indicador</th>
                  <th class="text-xs text-right">Valor (C$)</th>
                </tr>
              </thead>
              <tbody>
                <tr class="hover">
                  <td class="text-sm">N° de transacciones (n)</td>
                  <td class="text-right font-mono font-semibold"><%= @eda[:n] %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Media (promedio)</td>
                  <td class="text-right font-mono font-semibold tabular-nums"><%= number_with_precision(@eda[:media], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Mediana (P50)</td>
                  <td class="text-right font-mono font-semibold tabular-nums"><%= number_with_precision(@eda[:mediana], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Desviación estándar</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:desv_std], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Mínimo</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:vmin], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Máximo</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:vmax], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Percentil 25 (Q1)</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:p25], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Percentil 75 (Q3)</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:p75], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Rango intercuartílico (IQR)</td>
                  <td class="text-right font-mono tabular-nums"><%= number_with_precision(@eda[:rango_iqr], precision: 2, delimiter: ',') %></td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Coeficiente de variación</td>
                  <td class="text-right font-mono tabular-nums"><%= @eda[:coef_variacion] %>%</td>
                </tr>
                <tr class="hover">
                  <td class="text-sm">Asimetría (skewness)</td>
                  <td class="text-right font-mono tabular-nums"><%= @eda[:asimetria] %></td>
                </tr>
              </tbody>
            </table>
          </div>

          <%# Interpretación automática %>
          <div class="mt-3 p-3 rounded-lg bg-base-200/60 text-xs text-base-content/70 space-y-1">
            <p class="font-semibold text-base-content/80 mb-1">📊 Interpretación:</p>
            <% if @eda[:coef_variacion] > 50 %>
              <p>• <strong>Alta variabilidad</strong> (CV = <%= @eda[:coef_variacion] %>%): los montos de venta son muy dispersos.</p>
            <% elsif @eda[:coef_variacion] > 20 %>
              <p>• <strong>Variabilidad moderada</strong> (CV = <%= @eda[:coef_variacion] %>%): hay cierta dispersión en los montos.</p>
            <% else %>
              <p>• <strong>Baja variabilidad</strong> (CV = <%= @eda[:coef_variacion] %>%): los montos de venta son consistentes.</p>
            <% end %>

            <% if @eda[:asimetria] > 0.5 %>
              <p>• <strong>Distribución sesgada a la derecha</strong>: la mayoría de ventas son bajas, pero hay algunas de alto valor.</p>
            <% elsif @eda[:asimetria] < -0.5 %>
              <p>• <strong>Distribución sesgada a la izquierda</strong>: la mayoría de ventas son de alto valor.</p>
            <% else %>
              <p>• <strong>Distribución aproximadamente simétrica</strong>: los montos se distribuyen uniformemente alrededor de la media.</p>
            <% end %>

            <% if @eda[:media] > @eda[:mediana] %>
              <p>• La media (C$ <%= number_with_precision(@eda[:media], precision: 0, delimiter: ',') %>) es mayor que la mediana (C$ <%= number_with_precision(@eda[:mediana], precision: 0, delimiter: ',') %>), indicando ventas de alto valor que elevan el promedio.</p>
            <% else %>
              <p>• La media y mediana son similares (C$ <%= number_with_precision(@eda[:media], precision: 0, delimiter: ',') %> vs C$ <%= number_with_precision(@eda[:mediana], precision: 0, delimiter: ',') %>).</p>
            <% end %>
          </div>
        </div>

        <%# Histograma de distribución %>
        <div>
          <h3 class="text-sm font-semibold text-base-content/70 mb-2 uppercase tracking-wide">Distribución de Ventas (Histograma)</h3>
          <div class="h-64">
            <canvas id="histogramaVentasChart"></canvas>
          </div>
        </div>

      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-10 text-base-content/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        <p class="text-sm">No hay suficientes datos para el análisis en el período seleccionado.</p>
      </div>
    <% end %>
  </div>
</div>
