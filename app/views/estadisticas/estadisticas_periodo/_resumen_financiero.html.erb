<%# ── Resumen Financiero del Período ──────────────────────────────────── %>
<div class="card bg-base-100 shadow-sm border border-base-200 mb-4">
  <div class="card-body p-4">
    <h2 class="card-title text-base">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Resumen Financiero del Período
      <span class="text-xs font-normal text-base-content/50 ml-2">
        <%= @fecha_desde.strftime("%d/%m/%Y") %> — <%= @fecha_hasta.strftime("%d/%m/%Y") %>
      </span>
    </h2>

    <div class="overflow-x-auto mt-3">
      <table class="table table-sm">
        <thead>
          <tr class="bg-base-200/50">
            <th colspan="2" class="text-primary text-sm">Concepto</th>
            <th class="text-right text-primary text-sm">Monto (C$)</th>
          </tr>
        </thead>
        <tbody>

          <%# ── INGRESOS ── %>
          <tr class="bg-success/5">
            <td colspan="3" class="font-bold text-success text-sm pt-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
              INGRESOS
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">
              Ventas del período
              <span class="badge badge-ghost badge-xs ml-1"><%= @total_ventas_count %> transacciones</span>
            </td>
            <td class="text-right tabular-nums font-semibold text-success">
              <%= number_with_precision(@ingresos_brutos, precision: 2, delimiter: ',') %>
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">
              Artículos vendidos
            </td>
            <td class="text-right tabular-nums font-medium">
              <%= number_with_delimiter(@total_articulos_vendidos) %> unidades
            </td>
          </tr>
          <tr class="border-t border-success/20 font-bold">
            <td class="pl-6" colspan="2">Total Ingresos</td>
            <td class="text-right tabular-nums text-success text-base">
              <%= number_with_precision(@ingresos_brutos, precision: 2, delimiter: ',') %>
            </td>
          </tr>

          <%# ── COSTOS DE VENTA ── %>
          <tr class="bg-warning/5">
            <td colspan="3" class="font-bold text-warning text-sm pt-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              COSTO DE VENTAS (COGS)
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">Costo promedio ponderado × unidades vendidas</td>
            <td class="text-right tabular-nums font-semibold text-warning">
              (<%= number_with_precision(@cogs, precision: 2, delimiter: ',') %>)
            </td>
          </tr>
          <tr class="border-t border-base-200 font-bold">
            <td class="pl-6" colspan="2">
              Utilidad Bruta
              <span class="badge badge-sm <%= @margen_bruto_pct >= 0 ? 'badge-success' : 'badge-error' %> ml-1">
                <%= @margen_bruto_pct %>%
              </span>
            </td>
            <td class="text-right tabular-nums text-base <%= @utilidad_bruta >= 0 ? 'text-success' : 'text-error' %>">
              <%= number_with_precision(@utilidad_bruta, precision: 2, delimiter: ',') %>
            </td>
          </tr>

          <%# ── GASTOS OPERATIVOS ── %>
          <tr class="bg-error/5">
            <td colspan="3" class="font-bold text-error text-sm pt-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/>
              </svg>
              GASTOS OPERATIVOS
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">Alquiler</td>
            <td class="text-right tabular-nums text-error/80">
              (<%= number_with_precision(@gastos_alquiler, precision: 2, delimiter: ',') %>)
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">Utilidades (servicios)</td>
            <td class="text-right tabular-nums text-error/80">
              (<%= number_with_precision(@gastos_utilidades, precision: 2, delimiter: ',') %>)
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">Mantenimiento</td>
            <td class="text-right tabular-nums text-error/80">
              (<%= number_with_precision(@gastos_mantenimiento, precision: 2, delimiter: ',') %>)
            </td>
          </tr>
          <tr class="border-t border-error/20 font-bold">
            <td class="pl-6" colspan="2">Total Gastos Operativos</td>
            <td class="text-right tabular-nums text-error text-base">
              (<%= number_with_precision(@gastos_operativos_total, precision: 2, delimiter: ',') %>)
            </td>
          </tr>

          <%# ── UTILIDAD NETA ── %>
          <tr class="bg-base-200 border-t-2 border-base-300">
            <td colspan="2" class="font-bold text-lg py-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline mr-1 <%= @utilidad_neta >= 0 ? 'text-info' : 'text-error' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
              </svg>
              UTILIDAD NETA
              <span class="badge badge-sm <%= @margen_neto_pct >= 0 ? 'badge-info' : 'badge-error' %> ml-1">
                Margen: <%= @margen_neto_pct %>%
              </span>
            </td>
            <td class="text-right tabular-nums font-bold text-lg py-3 <%= @utilidad_neta >= 0 ? 'text-info' : 'text-error' %>">
              C$ <%= number_with_precision(@utilidad_neta, precision: 2, delimiter: ',') %>
            </td>
          </tr>

          <%# ── COMPRAS (referencia) ── %>
          <tr class="bg-secondary/5">
            <td colspan="3" class="font-bold text-secondary text-sm pt-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              COMPRAS (REFERENCIA)
            </td>
          </tr>
          <tr class="hover">
            <td class="pl-6" colspan="2">Costo total de órdenes de compra del período</td>
            <td class="text-right tabular-nums font-semibold">
              C$ <%= number_with_precision(@costo_compras, precision: 2, delimiter: ',') %>
            </td>
          </tr>

        </tbody>
      </table>
    </div>

    <%# ── Nota aclaratoria ── %>
    <div class="mt-3 text-xs text-base-content/40 bg-base-200/50 rounded-lg p-3">
      <strong>Nota:</strong> Los egresos mostrados entre paréntesis representan salidas de dinero.
      El COGS se calcula con base en el costo promedio ponderado de cada producto.
      Las compras se muestran como referencia y no se restan de la utilidad (ya están reflejadas en el COGS).
    </div>
  </div>
</div>
