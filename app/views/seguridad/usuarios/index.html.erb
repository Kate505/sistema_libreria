<%= turbo_frame_tag "main_content" do %>
  <%= turbo_stream_from "usuarios" %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <div class="grid grid-rows-[auto_1fr] gap-6 h-[calc(100vh-10rem)] w-full page-grid">

    <div class="flex items-center justify-between shrink-0 flex-wrap gap-3">
      <h1 class="text-3xl font-bold page-title">Gestión de Usuarios</h1>
      <button class="btn btn-primary btn-sm sm:hidden" onclick="document.getElementById('mobile_form_modal').showModal()">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nuevo Usuario
      </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 min-h-0">

      <%# Desktop: inline form card %>
      <div class="card bg-base-100 shadow-xl overflow-hidden flex-col h-full lg:max-h-full hidden lg:flex">
        <div class="overflow-y-auto flex-1 p-0">
          <%= render "form", usuario: @usuario, lista_agregar_roles: @lista_agregar_roles, roles_usuario: @roles_usuario, suffix: "desktop" %>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl lg:col-span-2 flex flex-col h-full overflow-hidden">

        <div class="flex-1 overflow-y-auto table-scroll-wrapper" id="usuarios_table_container">
          <div id="usuarios_table" class="h-full">
            <%= render "table", usuarios: @usuarios %>
          </div>
        </div>

      </div>

    </div>

  </div>

  <dialog id="mobile_form_modal" class="modal modal-bottom lg:hidden">
    <div class="modal-box max-h-[85vh] overflow-y-auto">
      <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button></form>
      <%= render "form", usuario: @usuario, lista_agregar_roles: @lista_agregar_roles, roles_usuario: @roles_usuario, suffix: "mobile" %>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

<% end %>
