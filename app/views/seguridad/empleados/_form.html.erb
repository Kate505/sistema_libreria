<turbo-frame id="empleado_form">
  <%= form_with(model: empleado, url: empleado.new_record? ? seguridad_empleados_path : seguridad_empleado_path(empleado), method: empleado.new_record? ? :post : :patch, class: 'contents') do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">
        <%= empleado.new_record? ? "Agregar nuevo empleado" : "Actualizar empleado" %>
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="w-full">
          <%= f.label :primer_nombre, 'Primer Nombre', class: 'label pt-0' %>
          <%= f.text_field :primer_nombre, class: 'input input-bordered w-full validator', placeholder: 'Primer Nombre', required: true %>
        </div>

        <div class="w-full">
          <%= f.label :segundo_nombre, 'Segundo Nombre', class: 'label pt-0' %>
          <%= f.text_field :segundo_nombre, class: 'input input-bordered w-full', placeholder: 'Segundo Nombre' %>
        </div>

        <div class="w-full">
          <%= f.label :primer_apellido, 'Primer Apellido', class: 'label pt-0' %>
          <%= f.text_field :primer_apellido, class: 'input input-bordered w-full validator', placeholder: 'Primer Apellido', required: true %>
        </div>

        <div class="w-full">
          <%= f.label :segundo_apellido, 'Segundo Apellido', class: 'label pt-0' %>
          <%= f.text_field :segundo_apellido, class: 'input input-bordered w-full', placeholder: 'Segundo Apellido' %>
        </div>

        <div class="w-full" data-controller="cedula-mask">
          <%= f.label :cedula, 'Cédula', class: 'label pt-0' %>
          <%= f.text_field :cedula,
                           class: 'input input-bordered w-full validator',
                           placeholder: '000-000000-0000X',
                           pattern: '\d{3}-\d{6}-\d{4}[A-Z]',
                           maxlength: 16,
                           title: 'Formato: 000-000000-0000X (3 dígitos - 6 dígitos - 4 dígitos y 1 letra mayúscula)',
                           data: { cedula_mask_target: 'input' } %>
          <p class="validator-hint">Formato: 000-000000-0000X</p>
        </div>

        <div class="w-full">
          <%= f.label :telefono, 'Teléfono', class: 'label pt-0' %>

          <label class="input input-bordered validator flex items-center gap-2 w-full">
            <svg class="h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
              <g fill="none">
                <path d="M7.25 11.5C6.83579 11.5 6.5 11.8358 6.5 12.25C6.5 12.6642 6.83579 13 7.25 13H8.75C9.16421 13 9.5 12.6642 9.5 12.25C9.5 11.8358 9.16421 11.5 8.75 11.5H7.25Z" fill="currentColor"></path>
                <path fill-rule="evenodd" clip-rule="evenodd" d="M6 1C4.61929 1 3.5 2.11929 3.5 3.5V12.5C3.5 13.8807 4.61929 15 6 15H10C11.3807 15 12.5 13.8807 12.5 12.5V3.5C12.5 2.11929 11.3807 1 10 1H6ZM10 2.5H9.5V3C9.5 3.27614 9.27614 3.5 9 3.5H7C6.72386 3.5 6.5 3.27614 6.5 3V2.5H6C5.44771 2.5 5 2.94772 5 3.5V12.5C5 13.0523 5.44772 13.5 6 13.5H10C10.5523 13.5 11 13.0523 11 12.5V3.5C11 2.94772 10.5523 2.5 10 2.5Z" fill="currentColor"></path>
              </g>
            </svg>

            <%= f.text_field :telefono,
              class: 'tabular-nums w-full',
              placeholder: '00000000',
              type: 'tel',
              pattern: '[0-9]{8}',
              minlength: '8',
              maxlength: '8',
              title: 'Agregue un número telefónico válido de 8 dígitos' %>
          </label>
          <p class="validator-hint">Debe ser exactamente 8 dígitos numéricos</p>
        </div>

        <div class="w-full">
          <%= f.label :cargo, 'Cargo', class: 'label pt-0' %>
          <%= f.text_field :cargo, class: 'input input-bordered w-full', placeholder: 'Cargo' %>
        </div>

        <div class="w-full">
          <%= f.label :fecha_contratacion, 'Fecha de Contratación', class: 'label pt-0' %>
          <%= f.date_field :fecha_contratacion,
                           value: f.object.fecha_contratacion&.strftime('%Y-%m-%d'),
                           max: Date.current.iso8601,
                           data: { controller: 'datepicker' },
                           class: 'input input-bordered w-full validator' %>
        </div>

        <div class="w-full flex items-end pb-3">
          <%= f.label :pasivo, class: 'cursor-pointer label flex items-center gap-3' do %>
            <%= f.check_box :pasivo, class: 'checkbox' %>
            <span class="label-text">Pasivo</span>
          <% end %>
        </div>

        <div class="card-actions justify-end sm:col-span-2 col-span-full mt-2 gap-2">
          <%= save_button(f, style_class: 'btn btn-primary w-full sm:w-auto') %>
          <%= cancel_button(seguridad_empleados_path, frame_id: "empleado_form", style_class: 'btn btn-soft btn-error w-full sm:w-auto') %>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
