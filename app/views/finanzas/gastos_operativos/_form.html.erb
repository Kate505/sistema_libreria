<turbo-frame id="gasto_operativo_form">
  <%= form_with(model: gasto_operativo,
                url: finanzas_gastos_operativos_path,
                method: :post,
                class: 'contents') do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">
        Registrar Gasto Operativo
      </h2>

      <%# Errores %>
      <% if gasto_operativo.errors.any? %>
        <div class="alert alert-error text-sm py-2">
          <ul class="list-disc list-inside">
            <% gasto_operativo.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Fecha %>
        <div class="w-full">
          <%= f.label :fecha, 'Fecha', class: 'label pt-0' %>
          <%= f.date_field :fecha,
                           class: 'input input-bordered w-full validator',
                           max: Date.current.iso8601,
                           data: { controller: 'datepicker' },
                           required: true %>
        </div>

        <%# Cantidad (C$) %>
        <div class="w-full">
          <%= f.label :cantidad, 'Cantidad (C$)', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :cantidad, step: '0.01', min: 0.01, class: 'grow min-w-0', placeholder: '0.00', required: true %>
          </label>
        </div>

        <%# Descripción %>
        <div class="w-full sm:col-span-2">
          <%= f.label :descripcion, 'Descripción', class: 'label pt-0' %>
          <%= f.text_field :descripcion, class: 'input input-bordered w-full validator', placeholder: 'Descripción del gasto', required: true, maxlength: 255 %>
        </div>

        <%# Botones de acción %>
        <div class="card-actions justify-end sm:col-span-2 col-span-full mt-4 pt-4 border-t border-base-200 gap-2">
          <%= save_button(f) %>
          <%= cancel_button(finanzas_gastos_operativos_path, frame_id: "gasto_operativo_form", style_class: 'btn btn-soft btn-error w-full sm:w-auto') %>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
