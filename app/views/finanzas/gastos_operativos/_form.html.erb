<turbo-frame id="gasto_operativo_form">
  <%= form_with(model: gasto_operativo,
                url: gasto_operativo.new_record? ? finanzas_gastos_operativos_path : finanzas_gasto_operativo_path(gasto_operativo),
                method: gasto_operativo.new_record? ? :post : :patch,
                class: 'contents') do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">
        <%= gasto_operativo.new_record? ? "Registrar Gasto Operativo" : "Editar: #{gasto_operativo.periodo_legible}" %>
      </h2>

      <%# Errores %>
      <% if gasto_operativo.errors.any? %>
        <div class="alert alert-error text-sm py-2">
          <ul class="list-disc list-inside">
            <% gasto_operativo.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# === SECCIÓN: PERÍODO === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Período
          </div>
        </div>

        <%# Mes %>
        <div class="w-full">
          <%= f.label :periodo_mes, 'Mes', class: 'label pt-0' %>
          <%= f.select :periodo_mes,
                       [
                         ["Enero",      1],  ["Febrero",   2],  ["Marzo",    3],
                         ["Abril",      4],  ["Mayo",      5],  ["Junio",    6],
                         ["Julio",      7],  ["Agosto",    8],  ["Septiembre", 9],
                         ["Octubre",   10],  ["Noviembre", 11], ["Diciembre", 12]
                       ],
                       { include_blank: "— Seleccione un mes —" },
                       class: 'select select-bordered w-full', required: true %>
        </div>

        <%# Año %>
        <div class="w-full">
          <%= f.label :periodo_year, 'Año', class: 'label pt-0' %>
          <%= f.number_field :periodo_year,
                             min: 2001,
                             max: Date.today.year + 5,
                             class: 'input input-bordered w-full',
                             placeholder: Date.today.year.to_s,
                             required: true %>
        </div>

        <%# === SECCIÓN: COSTOS === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Costos
          </div>
        </div>

        <%# Costos de Alquiler %>
        <div class="w-full">
          <%= f.label :costos_alquiler, 'Alquiler', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :costos_alquiler, step: '0.01', min: 0, class: 'grow', placeholder: '0.00' %>
          </label>
        </div>

        <%# Costo Utilidades %>
        <div class="w-full">
          <%= f.label :costo_utilidades, 'Utilidades', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :costo_utilidades, step: '0.01', min: 0, class: 'grow', placeholder: '0.00' %>
          </label>
        </div>

        <%# Costo Mantenimiento %>
        <div class="w-full">
          <%= f.label :costo_mantenimiento, 'Mantenimiento', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :costo_mantenimiento, step: '0.01', min: 0, class: 'grow', placeholder: '0.00' %>
          </label>
        </div>



        <%# Botones de acción %>
        <div class="card-actions justify-end sm:col-span-2 col-span-full mt-4 pt-4 border-t border-base-200 gap-2">
          <%= save_button(f) %>
          <%= cancel_button(finanzas_gastos_operativos_path, frame_id: "gasto_operativo_form", style_class: 'btn btn-soft btn-error w-full sm:w-auto') %>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
