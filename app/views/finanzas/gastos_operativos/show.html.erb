<%= turbo_frame_tag "main_content" do %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <div class="flex flex-col gap-6 w-full">

    <%# Encabezado %>
    <div class="flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <%= link_to finanzas_gastos_operativos_path,
                    data: { turbo_frame: "main_content", turbo_action: "advance" },
                    class: "btn btn-ghost btn-sm btn-square" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <div>
          <h1 class="text-3xl font-bold">Gasto Operativo: <%= @gasto_operativo.periodo_legible %></h1>
          <p class="text-sm text-base-content/50">Detalle del período</p>
        </div>
      </div>

      <%# Resumen del gasto %>
      <%= render "finanzas/gastos_operativos/resumen", gasto_operativo: @gasto_operativo %>
    </div>

  </div>
<% end %>
