<turbo-frame id="detalle_pago_empleado_form">
  <%= form_with(
        model: [gasto_operativo, detalle_pago_empleado],
        url: detalle_pago_empleado.new_record? \
               ? finanzas_gasto_operativo_detalle_pagos_empleados_path(gasto_operativo)
               : finanzas_gasto_operativo_detalle_pago_empleado_path(gasto_operativo, detalle_pago_empleado),
        method: detalle_pago_empleado.new_record? ? :post : :patch,
        data: { controller: "nomina-calc" },
        class: 'contents'
      ) do |f| %>

    <div class="card-body">
      <h2 class="card-title text-lg">
        <%= detalle_pago_empleado.new_record? ? "Agregar Empleado a Nómina" : "Editar Pago: #{detalle_pago_empleado.empleado&.nombre_corto}" %>
      </h2>

      <%# Errores %>
      <% if detalle_pago_empleado.errors.any? %>
        <div class="alert alert-error text-sm py-2">
          <ul class="list-disc list-inside">
            <% detalle_pago_empleado.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# === EMPLEADO === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Empleado
          </div>
        </div>

        <div class="sm:col-span-2 w-full">
          <%= f.label :empleado_id, 'Empleado', class: 'label pt-0' %>
          <% empleados_options = Empleado.activos.order(:primer_apellido, :primer_nombre).map { |e| [e.nombre_completo, e.id, { "data-salario": e.salario_base, "data-transporte": e.viatico_transporte }] } %>
          <%= f.select :empleado_id,
                       empleados_options,
                       { include_blank: "— Seleccione un empleado —" },
                       class: 'select select-bordered w-full',
                       required: true,
                       data: {
                         nomina_calc_target: "empleadoSelect",
                         action: "change->nomina-calc#cargarEmpleado"
                       },
                       disabled: !detalle_pago_empleado.new_record? %>
          <% if !detalle_pago_empleado.new_record? %>
            <%= f.hidden_field :empleado_id %>
          <% end %>
        </div>

        <%# === INGRESOS === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Ingresos
          </div>
        </div>

        <%# Salario Base %>
        <div class="w-full">
          <%= f.label :salario_base, 'Salario Base', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :salario_base, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "salarioBase",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Pago de Transporte %>
        <div class="w-full">
          <%= f.label :pago_transporte, 'Transporte / Viáticos', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :pago_transporte, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "pagoTransporte",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Comisiones %>
        <div class="w-full">
          <%= f.label :comisiones_ventas, 'Comisiones en Ventas', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :comisiones_ventas, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "comisionesVentas",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Horas Extra %>
        <div class="w-full">
          <%= f.label :horas_extra, 'Horas Extra', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :horas_extra, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "horasExtra",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Salario Bruto (calculado) %>
        <div class="sm:col-span-2">
          <div class="bg-base-200 rounded-lg px-4 py-2 flex justify-between items-center">
            <span class="text-sm font-semibold text-base-content/70">Salario Bruto</span>
            <span class="text-base font-bold text-primary" data-nomina-calc-target="salarioBruto">
              C$ <%= number_with_precision(detalle_pago_empleado.salario_bruto || 0, precision: 2, delimiter: ',') %>
            </span>
          </div>
        </div>

        <%# === DEDUCCIONES === %>
        <div class="sm:col-span-2">
          <div class="divider divider-start text-xs font-semibold text-base-content/50 uppercase tracking-wider my-1">
            Deducciones
          </div>
        </div>

        <%# INSS Laboral (7%) %>
        <div class="w-full">
          <%= f.label :deduccion_inss, 'INSS Laboral (7%)', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :deduccion_inss, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "deduccionInss",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# IR / Impuestos %>
        <div class="w-full">
          <%= f.label :deduccion_impuestos, 'IR / Impuesto sobre la Renta', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :deduccion_impuestos, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "deduccionImpuestos",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Otras Deducciones %>
        <div class="w-full">
          <%= f.label :otras_deducciones, 'Otras Deducciones', class: 'label pt-0' %>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <span class="text-base-content/60 text-sm font-semibold">C$</span>
            <%= f.number_field :otras_deducciones, step: '0.01', min: 0, class: 'grow',
                               placeholder: '0.00',
                               data: {
                                 nomina_calc_target: "otrasDeducciones",
                                 action: "input->nomina-calc#calcular"
                               } %>
          </label>
        </div>

        <%# Salario Neto (calculado) %>
        <div class="sm:col-span-2">
          <div class="bg-success/10 border border-success/30 rounded-lg px-4 py-2 flex justify-between items-center">
            <span class="text-sm font-bold text-success">Salario Neto</span>
            <span class="text-base font-bold text-success" data-nomina-calc-target="salarioNeto">
              C$ <%= number_with_precision(detalle_pago_empleado.salario_neto || 0, precision: 2, delimiter: ',') %>
            </span>
          </div>
        </div>

        <%# Botones %>
        <div class="card-actions justify-end sm:col-span-2 col-span-full mt-4 pt-4 border-t border-base-200 gap-2">
          <%= save_button(f) %>
          <%= cancel_button(finanzas_gasto_operativo_path(gasto_operativo), frame_id: "detalle_pago_empleado_form", style_class: 'btn btn-soft btn-error btn-sm') %>
        </div>

      </div>
    </div>
  <% end %>
</turbo-frame>
