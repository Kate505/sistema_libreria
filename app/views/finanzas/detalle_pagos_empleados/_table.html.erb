<table class="table table-pin-rows table-xs px-2">
  <thead>
    <tr class="bg-base-100 z-10 text-xs">
      <th>Empleado</th>
      <th class="text-right">Salario Base</th>
      <th class="text-right">Transporte</th>
      <th class="text-right">Comisiones</th>
      <th class="text-right">H. Extra</th>
      <th class="text-right font-bold">Bruto</th>
      <th class="text-right text-error">INSS</th>
      <th class="text-right text-error">IR</th>
      <th class="text-right text-error">Otras Ded.</th>
      <th class="text-right font-bold text-success">Neto</th>
      <th class="text-right">Acciones</th>
    </tr>
  </thead>

  <tbody>
  <% detalle_pagos_empleados.each do |detalle| %>
    <tr class="hover:bg-base-200" id="detalle_pago_empleado_<%= detalle.id %>">
      <td>
        <div class="flex flex-col">
          <span class="font-semibold text-xs"><%= detalle.empleado.nombre_corto %></span>
          <span class="text-xs text-base-content/40"><%= detalle.empleado.cargo.presence || "—" %></span>
        </div>
      </td>
      <td class="text-right tabular-nums text-xs">
        C$ <%= number_with_precision(detalle.salario_base, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs">
        C$ <%= number_with_precision(detalle.pago_transporte, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs">
        C$ <%= number_with_precision(detalle.comisiones_ventas, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs">
        C$ <%= number_with_precision(detalle.horas_extra, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs font-semibold">
        C$ <%= number_with_precision(detalle.salario_bruto, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs text-error">
        C$ <%= number_with_precision(detalle.deduccion_inss, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs text-error">
        C$ <%= number_with_precision(detalle.deduccion_impuestos, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs text-error">
        C$ <%= number_with_precision(detalle.otras_deducciones, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right tabular-nums text-xs font-bold text-success">
        C$ <%= number_with_precision(detalle.salario_neto, precision: 2, delimiter: ',') %>
      </td>
      <td class="text-right">
        <div class="flex gap-1 justify-end">
          <%= link_to edit_finanzas_gasto_operativo_detalle_pago_empleado_path(gasto_operativo, detalle),
                      data: { turbo_frame: "detalle_pago_empleado_form" },
                      class: "btn btn-xs btn-ghost btn-square",
                      title: "Editar" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16">
              <path fill="currentColor" d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456l-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
              <path fill="currentColor" fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
            </svg>
          <% end %>

          <%= link_to finanzas_gasto_operativo_detalle_pago_empleado_path(gasto_operativo, detalle),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "¿Eliminar el pago de #{detalle.empleado.nombre_corto} de la nómina? Esta acción no se puede deshacer."
                      },
                      class: "btn btn-xs btn-ghost btn-square text-error",
                      title: "Eliminar" do %>
            <% inline_svg "remove.svg" %>
          <% end %>
        </div>
      </td>
    </tr>
  <% end %>

  <% if detalle_pagos_empleados.empty? %>
    <tr>
      <td colspan="11" class="text-center py-12 text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <p class="text-sm">No hay empleados en esta nómina todavía</p>
        <p class="text-xs text-base-content/30 mt-1">Usa el formulario de la izquierda para agregar empleados</p>
      </td>
    </tr>
  <% end %>

  </tbody>

  <% if detalle_pagos_empleados.any? %>
    <tfoot>
      <tr class="bg-base-200 font-bold">
        <td class="text-xs">Totales (<%= detalle_pagos_empleados.size %> empleados)</td>
        <td class="text-right tabular-nums text-xs">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:salario_base), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:pago_transporte), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:comisiones_ventas), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:horas_extra), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs text-primary">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:salario_bruto), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs text-error">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:deduccion_inss), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs text-error">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:deduccion_impuestos), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs text-error">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:otras_deducciones), precision: 2, delimiter: ',') %>
        </td>
        <td class="text-right tabular-nums text-xs text-success">
          C$ <%= number_with_precision(detalle_pagos_empleados.sum(&:salario_neto), precision: 2, delimiter: ',') %>
        </td>
        <td></td>
      </tr>
    </tfoot>
  <% end %>
</table>
