<% if categorias.any? %>
  <div class="divide-y divide-base-200">
    <% categorias.each do |cat| %>
      <div class="flex items-center justify-between py-2 px-1 hover:bg-base-200 rounded-lg">
        <div>
          <p class="font-medium text-sm"><%= cat.nombre %></p>
          <% if cat.descripcion.present? %>
            <p class="text-xs text-base-content/50"><%= cat.descripcion %></p>
          <% end %>
        </div>
        <div class="flex gap-1 shrink-0">
          <%= link_to edit_finanzas_categoria_egreso_path(cat),
                      data: { turbo_frame: "categoria_egreso_form" },
                      class: "btn btn-xs btn-ghost btn-square",
                      title: "Editar" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 16 16">
              <path fill="currentColor" d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456l-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
              <path fill="currentColor" fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
            </svg>
          <% end %>
          <%= link_to finanzas_categoria_egreso_path(cat),
                      data: { turbo_method: :delete,
                              turbo_confirm: "¿Eliminar la categoría \"#{cat.nombre}\"?" },
                      class: "btn btn-xs btn-ghost btn-square text-error",
                      title: "Eliminar" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
              <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
            </svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-base-content/40 text-center py-4">No hay categorías registradas.</p>
<% end %>
