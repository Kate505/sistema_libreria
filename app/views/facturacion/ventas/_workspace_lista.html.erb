<%# Estado A: Lista de ventas pendientes + formulario nueva venta %>
<div id="ventas_workspace" class="h-full flex flex-col gap-6 min-h-0">

<div class="flex items-center justify-between shrink-0 flex-wrap gap-3">
  <h1 class="text-3xl font-bold page-title">Ventas</h1>
  <div class="flex items-center gap-2">
    <%# Mobile: open form modal %>
    <button class="btn btn-primary btn-sm lg:hidden" onclick="document.getElementById('mobile_form_modal').showModal()">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nueva Venta
    </button>
    <%= link_to historial_facturacion_ventas_path,
                data: { turbo_frame: "main_content", turbo_action: "advance" },
                class: "btn btn-ghost btn-sm gap-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      Historial de Ventas
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 min-h-0 flex-1">

  <%# Desktop: inline form card (hidden on mobile) %>
  <div class="card bg-base-100 shadow-xl overflow-hidden flex-col h-full lg:max-h-full hidden lg:flex">
    <div class="overflow-y-auto flex-1 p-0">
      <%= render "form", venta: venta, suffix: "desktop" %>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl lg:col-span-2 flex flex-col h-full overflow-hidden">
    <div class="flex-1 overflow-y-auto table-scroll-wrapper" id="ventas_table_container">
      <div id="ventas_table" class="h-full">
        <%= render "table", ventas: ventas %>
      </div>
    </div>
  </div>

</div>

<%# Mobile form modal %>
<dialog id="mobile_form_modal" class="modal modal-bottom lg:hidden">
  <div class="modal-box max-h-[85vh]">
    <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button></form>
    <%= render "form", venta: venta, suffix: "mobile" %>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
</div>
