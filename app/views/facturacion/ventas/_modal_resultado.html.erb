<%# Resultado mostrado en el modal tras finalizar la venta %>
<div id="modal_finalizar"
     data-controller="auto-print"
     data-auto-print-url-value="<%= facturacion_venta_path(venta, format: :pdf) %>">
  <dialog id="dialog_finalizar" class="modal modal-bottom sm:modal-middle" open>
    <div class="modal-box w-full max-w-lg p-0 overflow-hidden">

      <%# Encabezado success %>
      <div class="bg-success px-6 py-5 text-center">
        <div class="flex justify-center mb-2">
          <div class="bg-success-content/20 rounded-full p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-success-content" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
        <h3 class="font-bold text-xl text-success-content">¡Venta Finalizada!</h3>
        <p class="text-success-content/80 text-sm mt-1">Venta #<%= venta.id %> completada exitosamente</p>
      </div>

      <%# Detalles del pago %>
      <div class="px-6 py-5 space-y-3">

        <div class="flex justify-between items-center py-2 border-b border-base-200">
          <span class="text-sm text-base-content/60">Método de pago</span>
          <span class="font-semibold"><%= Venta::METODOS_PAGO[venta.metodo_pago] || venta.metodo_pago %></span>
        </div>

        <div class="flex justify-between items-center py-2 border-b border-base-200">
          <span class="text-sm text-base-content/60">Total cobrado</span>
          <span class="font-bold text-lg tabular-nums">
            C$ <%= number_with_precision(venta.cantidad_total, precision: 2, delimiter: ',') %>
          </span>
        </div>

        <% if venta.metodo_pago == "E" %>
          <% if moneda == "USD" %>
            <div class="flex justify-between items-center py-2 border-b border-base-200">
              <span class="text-sm text-base-content/60">Tasa de cambio</span>
              <span class="font-medium tabular-nums">C$ <%= number_with_precision(tasa_cambio, precision: 2) %> / US$</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-base-200">
              <span class="text-sm text-base-content/60">Monto recibido</span>
              <span class="font-semibold tabular-nums">
                US$ <%= number_with_precision(monto_recibido, precision: 2) %>
                <span class="text-xs text-base-content/40">
                  (≈ C$ <%= number_with_precision(monto_recibido * tasa_cambio, precision: 2, delimiter: ',') %>)
                </span>
              </span>
            </div>
          <% else %>
            <div class="flex justify-between items-center py-2 border-b border-base-200">
              <span class="text-sm text-base-content/60">Monto recibido</span>
              <span class="font-semibold tabular-nums">
                C$ <%= number_with_precision(monto_recibido, precision: 2, delimiter: ',') %>
              </span>
            </div>
          <% end %>

          <%# Vuelto %>
          <% if vuelto && vuelto >= 0 %>
            <div class="rounded-box p-4 <%= vuelto > 0 ? 'bg-success/10 border border-success/30' : 'bg-base-200' %>">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-sm <%= vuelto > 0 ? 'text-success' : 'text-base-content/60' %>">
                  Vuelto al cliente
                </span>
                <span class="font-bold text-xl tabular-nums <%= vuelto > 0 ? 'text-success' : '' %>">
                  C$ <%= number_with_precision(vuelto, precision: 2, delimiter: ',') %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>

      </div>

      <%# Acciones %>
      <div class="px-6 pb-6 flex gap-2">
        <button class="btn btn-ghost"
                onclick="document.getElementById('dialog_finalizar').close()">
          Cerrar
        </button>
        
        <%= link_to facturacion_venta_path(venta, format: :pdf),
                    target: "_blank",
                    class: "btn btn-outline btn-primary flex-1 gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Imprimir
        <% end %>

        <%= link_to facturacion_ventas_path,
                    data: { turbo_frame: "main_content", turbo_action: "advance" },
                    class: "btn btn-primary flex-1 gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Nueva Venta
        <% end %>
      </div>

    </div>
    <form method="dialog" class="modal-backdrop"><button>cerrar</button></form>
  </dialog>
</div>
