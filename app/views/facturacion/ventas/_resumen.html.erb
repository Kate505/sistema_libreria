<turbo-frame id="venta_resumen">
  <% total = venta.cantidad_total.to_d %>
  <% count = venta.detalle_ventas.size %>

  <div class="flex flex-wrap items-center gap-3">
    <div class="stats stats-horizontal shadow">
      <div class="stat py-2 px-4">
        <div class="stat-title text-xs">Productos</div>
        <div class="stat-value text-lg"><%= count %></div>
      </div>
      <div class="stat py-2 px-4 bg-primary/10 rounded-box">
        <div class="stat-title text-xs font-bold text-primary">Total Venta</div>
        <div class="stat-value text-lg tabular-nums text-primary">C$ <%= number_with_precision(total, precision: 2, delimiter: ',') %></div>
      </div>
    </div>

    <% if venta.pendiente? && count > 0 %>
      <%# Botón para abrir el modal de finalizar %>
      <button class="btn btn-success gap-2"
              onclick="document.getElementById('dialog_finalizar').showModal()">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Finalizar Transacción
      </button>
    <% elsif venta.finalizada? %>
      <div class="flex items-center gap-2">
        <span class="badge badge-success badge-lg gap-1 font-semibold">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <%= Venta::METODOS_PAGO[venta.metodo_pago] %>
        </span>
        
        <%= link_to facturacion_venta_path(venta, format: :pdf),
                    target: "_blank",
                    class: "btn btn-outline btn-primary btn-sm gap-2",
                    title: "Imprimir Factura" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Imprimir
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Contenedor del modal (se reemplaza por turbo_stream al finalizar) %>
  <%= render "facturacion/ventas/modal_finalizar", venta: venta %>

</turbo-frame>

