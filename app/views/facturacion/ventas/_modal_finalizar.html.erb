<%# Modal de Finalización de Transacción %>
<div id="modal_finalizar">
  <dialog id="dialog_finalizar" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box w-full max-w-lg p-0 overflow-hidden">

      <%# Encabezado %>
      <div class="bg-primary px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-content" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <h3 class="font-bold text-lg text-primary-content">Finalizar Transacción</h3>
        </div>
        <button class="btn btn-ghost btn-sm btn-square text-primary-content" onclick="document.getElementById('dialog_finalizar').close()">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# Total a pagar %>
      <div class="px-6 py-4 bg-primary/5 border-b border-base-200">
        <div class="flex items-center justify-between">
          <span class="text-sm text-base-content/60 font-medium">Total a cobrar</span>
          <span class="text-2xl font-bold tabular-nums text-primary">
            C$ <%= number_with_precision(venta.cantidad_total, precision: 2, delimiter: ',') %>
          </span>
        </div>
        <p class="text-xs text-base-content/40 mt-1"><%= venta.detalle_ventas.size %> producto(s)</p>
      </div>

      <%# Error %>
      <% if local_assigns[:error].present? %>
        <div class="mx-6 mt-4 alert alert-error text-sm py-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.538-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <span><%= error %></span>
        </div>
      <% end %>

      <%# Formulario de pago %>
      <%= form_with url: finalizar_facturacion_venta_path(venta),
                    method: :patch,
                    data: { controller: "pago-finalizar" },
                    class: "px-6 py-4 space-y-5" do |f| %>

        <%# Moneda %>
        <div>
          <label class="label pt-0 pb-1">
            <span class="label-text font-semibold">Moneda de pago</span>
          </label>
          <div class="flex gap-3">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="moneda" value="NIO" class="radio radio-primary radio-sm"
                     checked
                     data-action="change->pago-finalizar#monedaChange">
              <span class="text-sm font-medium">Córdobas (C$)</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="moneda" value="USD" class="radio radio-primary radio-sm"
                     data-action="change->pago-finalizar#monedaChange">
              <span class="text-sm font-medium">Dólares (US$)</span>
            </label>
          </div>
        </div>

        <%# Tasa de cambio (solo si USD) %>
        <div data-pago-finalizar-target="tasaContainer" class="hidden">
          <label class="label pt-0 pb-1">
            <span class="label-text font-semibold">Tasa de cambio fija</span>
            <span class="label-text-alt text-base-content/50">C$ por 1 US$</span>
          </label>

          <%# La tasa es fija por requerimiento: C$ 36.70 por US$ 1 %>
          <div class="rounded-box p-3 bg-base-200/60 border border-base-300 flex items-center justify-between">
            <span class="text-sm text-base-content/60 font-medium">C$ / US$</span>
            <span class="text-sm font-semibold tabular-nums text-base-content">36.70</span>
          </div>

          <input type="hidden"
                 name="tasa_cambio"
                 id="tasa_cambio"
                 value="36.70"
                 data-pago-finalizar-target="tasa">

          <p class="text-xs text-base-content/40 mt-1">Tasa fija configurada por el sistema.</p>
        </div>

        <%# Método de pago %>
        <div>
          <label class="label pt-0 pb-1">
            <span class="label-text font-semibold">Método de pago</span>
          </label>
          <div class="grid grid-cols-2 gap-2">
            <% Venta::METODOS_PAGO.each do |clave, nombre| %>
              <label class="cursor-pointer">
                <input type="radio" name="metodo_pago" value="<%= clave %>"
                       class="sr-only peer"
                       data-action="change->pago-finalizar#metodoPagoChange">
                <div class="border-2 border-base-300 rounded-box p-3 text-center text-sm font-medium
                            peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:text-primary
                            hover:border-primary/50 transition-all">
                  <% if clave == "E" %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                  <% else %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                    </svg>
                  <% end %>
                  <%= nombre %>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# Monto recibido (solo si Efectivo) %>
        <div data-pago-finalizar-target="efectivoContainer" class="hidden space-y-3">
          <div>
            <label class="label pt-0 pb-1">
              <span class="label-text font-semibold">Monto recibido</span>
              <span class="label-text-alt text-base-content/50" data-pago-finalizar-target="monedaLabel">C$</span>
            </label>
            <label class="input input-bordered flex items-center gap-2 w-full text-lg">
              <span class="text-base-content/60 text-sm font-semibold" data-pago-finalizar-target="monedaPrefix">C$</span>
              <input type="number"
                     name="monto_recibido"
                     id="monto_recibido"
                     step="0.01"
                     min="0"
                     placeholder="0.00"
                     class="grow font-bold"
                     data-pago-finalizar-target="montoRecibido"
                     data-action="input->pago-finalizar#calcularVuelto">
            </label>
          </div>

          <%# Preview del vuelto %>
          <div data-pago-finalizar-target="vueltoPreview"
               class="rounded-box p-3 bg-base-200 hidden">
            <div class="flex items-center justify-between">
              <span class="text-sm text-base-content/60">Vuelto estimado</span>
              <span class="font-bold tabular-nums text-lg"
                    data-pago-finalizar-target="vueltoValor">C$ 0.00</span>
            </div>
            <div data-pago-finalizar-target="vueltoInsuficiente"
                 class="hidden text-xs text-error mt-1 flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.538-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              Monto insuficiente para cubrir el total.
            </div>
          </div>
        </div>

        <%# Total en dólares (referencia) %>
        <div data-pago-finalizar-target="totalUsdContainer" class="hidden">
          <div class="rounded-box p-3 bg-info/10 border border-info/20">
            <div class="flex items-center justify-between">
              <span class="text-xs text-base-content/70 font-medium">Total equivalente en US$</span>
              <span class="font-semibold tabular-nums text-base-content"
                    data-pago-finalizar-target="totalUsd">US$ —</span>
            </div>
          </div>
        </div>

        <input type="hidden"
               name="total_nios"
               value="<%= venta.cantidad_total.to_d %>">

        <%# Botones %>
        <div class="flex gap-3 pt-2 pb-2 border-t border-base-200">
          <button type="button"
                  class="btn btn-ghost flex-1"
                  onclick="document.getElementById('dialog_finalizar').close()">
            Cancelar
          </button>
          <button type="submit"
                  class="btn btn-primary flex-1 gap-2"
                  data-pago-finalizar-target="submitBtn">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Confirmar Pago
          </button>
        </div>

      <% end %>
    </div>
    <form method="dialog" class="modal-backdrop"><button>cerrar</button></form>
  </dialog>
</div>
