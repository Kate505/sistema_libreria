<table class="table table-pin-rows">
  <thead>
    <tr class="bg-base-100 z-10">
      <th>Producto</th>
      <th class="text-center">Cantidad</th>
      <th class="text-right">P. Venta Unit.</th>
      <th class="text-right">Subtotal</th>
      <th class="text-right">Acción</th>
    </tr>
  </thead>

  <tbody>
  <% detalles.each do |detalle| %>
    <tr class="hover:bg-base-200">

      <td class="font-medium max-w-xs">
        <div class="flex flex-col">
          <span class="truncate"><%= detalle.producto.nombre %></span>
          <% if detalle.producto.sku.present? %>
            <span class="text-xs text-base-content/40 font-mono"><%= detalle.producto.sku %></span>
          <% end %>
          <% if detalle.precio_historico_al_momento_de_venta.present? &&
                detalle.precio_historico_al_momento_de_venta != detalle.precio_unitario_venta %>
            <span class="text-xs text-warning/70">
              Precio orig.: C$ <%= number_with_precision(detalle.precio_historico_al_momento_de_venta, precision: 2) %>
            </span>
          <% end %>
        </div>
      </td>

      <td class="text-center tabular-nums font-semibold">
        <%= detalle.cantidad %>
      </td>

      <td class="text-right tabular-nums text-sm">
        C$ <%= number_with_precision(detalle.precio_unitario_venta, precision: 2, delimiter: ',') %>
      </td>

      <td class="text-right font-semibold tabular-nums">
        C$ <%= number_with_precision(detalle.subtotal, precision: 2, delimiter: ',') %>
      </td>

      <td class="text-right">
        <%= link_to facturacion_venta_detalle_venta_path(venta, detalle),
                    data: { turbo_method: :delete,
                            turbo_confirm: "¿Eliminar #{detalle.producto.nombre} de esta venta? Se restaurarán #{detalle.cantidad} unidades al stock." },
                    class: "btn btn-sm btn-ghost btn-square text-error",
                    title: "Eliminar línea" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14H6L5 6"/>
            <path d="M10 11v6M14 11v6"/>
            <path d="M9 6V4h6v2"/>
          </svg>
        <% end %>
      </td>

    </tr>
  <% end %>

  <% if detalles.empty? %>
    <tr>
      <td colspan="5" class="text-center py-16 text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <p class="text-sm">Sin productos agregados. Usa el formulario de la izquierda.</p>
      </td>
    </tr>
  <% end %>

  </tbody>

  <% if detalles.any? %>
    <tfoot>
      <tr class="bg-base-200/50">
        <td colspan="3" class="text-right font-semibold text-sm">Total Venta:</td>
        <td class="text-right font-bold tabular-nums">
          <% total = detalles.sum { |d| d.subtotal } %>
          C$ <%= number_with_precision(total, precision: 2, delimiter: ',') %>
        </td>
        <td></td>
      </tr>
    </tfoot>
  <% end %>

</table>
