<turbo-frame id="detalle_venta_form">
  <% if venta.finalizada? %>
    <%# Venta cerrada: mostrar mensaje bloqueante %>
    <div class="card-body flex flex-col items-center justify-center h-full text-center gap-4 py-12">
      <div class="bg-success/10 rounded-full p-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="font-bold text-base-content">Venta Finalizada</p>
        <p class="text-sm text-base-content/50 mt-1">
          Esta venta fue cobrada con<br>
          <span class="font-semibold text-base-content/70"><%= Venta::METODOS_PAGO[venta.metodo_pago] || venta.metodo_pago %></span>.
          No se pueden agregar más productos.
        </p>
      </div>
    </div>
  <% else %>
    <%# Venta abierta: formulario normal para agregar productos %>
    <%= form_with(model: [venta, detalle],
                  url: facturacion_venta_detalle_ventas_path(venta),
                  method: :post,
                  class: 'contents') do |f| %>

      <div class="card-body">
        <h2 class="card-title text-lg">Agregar Producto</h2>

        <%# Errores %>
        <% if detalle.errors.any? %>
          <div class="alert alert-error text-sm py-2">
            <ul class="list-disc list-inside">
              <% detalle.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 gap-4">

          <%# Producto - Autocomplete %>
          <div class="w-full relative"
               data-controller="autocomplete"
               data-autocomplete-url-value="<%= buscar_producto_facturacion_ventas_path %>"
               data-action="click@window->autocomplete#hide"
               data-autocomplete-extra-fields-value='{"precio_unitario_venta": "precio", "stock_info": "stock"}'>

            <%= f.label :producto_id, 'Producto', class: 'label pt-0' %>
            <%= f.hidden_field :producto_id, data: { autocomplete_target: "hidden" } %>

            <div class="relative">
              <% nombre_producto = detalle.producto_id.present? ? detalle.producto&.nombre : "" %>
              <input type="text"
                     class="input input-bordered w-full pr-10"
                     placeholder="Buscar por nombre o SKU..."
                     value="<%= nombre_producto %>"
                     data-autocomplete-target="input"
                     data-action="input->autocomplete#search"
                     autocomplete="off">

              <div data-autocomplete-target="loading" class="absolute right-3 top-3 hidden">
                <span class="loading loading-spinner loading-sm text-primary"></span>
              </div>
            </div>

            <ul data-autocomplete-target="results"
                class="menu flex-nowrap dropdown-content bg-base-100 rounded-box z-[50] w-full p-2 shadow-lg absolute top-full mt-1 border border-base-200 hidden max-h-60 overflow-y-auto">
            </ul>
          </div>

          <%# Stock disponible (informativo) %>
          <div id="stock_info" class="text-xs text-base-content/40 -mt-2 hidden">
            Stock disponible: <span id="stock_value"></span> unidades
          </div>

          <%# Cantidad %>
          <div class="w-full">
            <%= f.label :cantidad, 'Cantidad', class: 'label pt-0' %>
            <%= f.number_field :cantidad,
                               id: "detalle_cantidad",
                               min: 1,
                               step: 1,
                               class: 'input input-bordered w-full',
                               placeholder: '1',
                               required: true,
                               oninput: 'actualizarPrecioPorCantidad()' %>
          </div>

          <%# Precio de Venta Unitario — solo lectura %>
          <div class="w-full">
            <%= f.label :precio_unitario_venta, 'Precio Unitario Venta', class: 'label pt-0' %>
            <label class="input input-bordered flex items-center gap-2 w-full bg-base-200/60">
              <span class="text-base-content/60 text-sm font-semibold">C$</span>
              <%= f.number_field :precio_unitario_venta,
                                 id: "precio_unitario_venta",
                                 step: 1, min: 0,
                                 class: 'grow cursor-not-allowed',
                                 placeholder: '0',
                                 required: true,
                                 readonly: true,
                                 tabindex: -1 %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </label>
            <div id="precio_tipo_info" class="hidden mt-1">
              <span id="precio_tipo_badge" class="badge badge-sm gap-1"></span>
            </div>
          </div>

          <%# ── Descuento — Control premium con slider + badge ── %>
          <div id="descuento_section" class="w-full hidden">
            <%= f.label :descuento_porcentaje, 'Descuento', class: 'label pt-0' %>

            <%# Contenedor con apariencia card %>
            <div class="bg-gradient-to-r from-warning/5 to-warning/10 border border-warning/20 rounded-xl p-4">

              <%# Fila superior: Badge visual + valor numérico %>
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <div class="bg-warning/20 rounded-lg p-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-base-content/70">Descuento aplicado</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <input type="number"
                         id="descuento_porcentaje"
                         name="detalle_venta[descuento_porcentaje]"
                         min="0" max="100" step="1"
                         value="<%= detalle.descuento_porcentaje.to_i %>"
                         class="input input-bordered input-sm w-16 text-center font-bold tabular-nums text-warning"
                         oninput="syncDescuentoSlider(this.value)">
                  <span class="text-sm font-bold text-warning">%</span>
                </div>
              </div>

              <%# Slider range con labels %>
              <div>
                <input type="range"
                       id="descuento_slider"
                       min="0" max="100" step="1"
                       value="<%= detalle.descuento_porcentaje.to_i %>"
                       class="range range-warning range-sm w-full"
                       oninput="syncDescuentoInput(this.value)">
                <div class="flex justify-between text-xs text-base-content/40 mt-1 px-0.5">
                  <span>0%</span>
                  <span id="descuento_max_label">Máx: —</span>
                </div>
              </div>

              <%# Info del máximo permitido %>
              <div id="descuento_limit_info" class="flex items-center gap-1.5 mt-2 text-xs text-warning/70">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>Máximo permitido: <strong id="descuento_max_value">0</strong>%</span>
              </div>
            </div>
          </div>

          <%# Acción %>
          <div class="card-actions justify-end mt-2 pt-4 border-t border-base-200">
            <button type="submit" class="btn btn-primary gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Agregar Producto
            </button>
          </div>

        </div>
      </div>
    <% end %>
  <% end %>
</turbo-frame>

<script>
  // ── Estado global del producto seleccionado ──
  var _precioNormal = 0;
  var _precioMayor = 0;
  var _descuentoMax = 0;
  var _descuentoPermitido = false;

  // ── Precio al mayor: cambia automáticamente cuando qty >= 3 ──
  function actualizarPrecioPorCantidad() {
    var cantField = document.getElementById("detalle_cantidad");
    var precioField = document.getElementById("precio_unitario_venta");
    var infoDiv = document.getElementById("precio_tipo_info");
    var badge = document.getElementById("precio_tipo_badge");
    if (!cantField || !precioField || _precioNormal === 0) return;

    var qty = parseInt(cantField.value) || 0;
    var usarMayor = qty >= 3 && _precioMayor > 0 && _precioMayor !== _precioNormal;
    var precio = usarMayor ? _precioMayor : _precioNormal;
    precioField.value = precio;

    // Badge indicador
    if (infoDiv && badge) {
      if (usarMayor) {
        badge.className = "badge badge-sm badge-info gap-1";
        badge.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg> Precio al mayor (≥3 uds.)';
        infoDiv.classList.remove("hidden");
      } else if (_precioMayor > 0 && _precioMayor !== _precioNormal) {
        badge.className = "badge badge-sm badge-ghost gap-1";
        badge.textContent = "Precio normal (al mayor desde 3 uds.)";
        infoDiv.classList.remove("hidden");
      } else {
        infoDiv.classList.add("hidden");
      }
    }
  }

  // ── Descuento ──
  function syncDescuentoInput(val) {
    val = Math.min(parseInt(val) || 0, _descuentoMax);
    var numField = document.getElementById("descuento_porcentaje");
    var slider = document.getElementById("descuento_slider");
    if (numField) numField.value = val;
    if (slider) slider.value = val;
  }

  function syncDescuentoSlider(val) {
    val = Math.min(parseInt(val) || 0, _descuentoMax);
    var numField = document.getElementById("descuento_porcentaje");
    var slider = document.getElementById("descuento_slider");
    if (numField) numField.value = val;
    if (slider) slider.value = val;
  }

  function configurarDescuento(permitido, maxVal) {
    _descuentoPermitido = permitido;
    _descuentoMax = permitido ? (parseInt(maxVal) || 0) : 0;

    var section = document.getElementById("descuento_section");
    var numField = document.getElementById("descuento_porcentaje");
    var slider = document.getElementById("descuento_slider");
    var maxLabel = document.getElementById("descuento_max_label");
    var maxValue = document.getElementById("descuento_max_value");

    if (!section) return;

    if (permitido && _descuentoMax > 0) {
      section.classList.remove("hidden");
      if (numField) { numField.max = _descuentoMax; numField.value = _descuentoMax; }
      if (slider)   { slider.max = _descuentoMax; slider.value = _descuentoMax; }
      if (maxLabel) maxLabel.textContent = "Máx: " + _descuentoMax + "%";
      if (maxValue) maxValue.textContent = _descuentoMax;
    } else {
      section.classList.add("hidden");
      if (numField) { numField.value = 0; numField.max = 0; }
      if (slider)   { slider.value = 0; slider.max = 0; }
    }
  }

  // ── Al seleccionar producto del autocomplete ──
  document.addEventListener("autocomplete:select", function(event) {
    var item = event.detail;
    if (item && item.precio !== undefined) {
      _precioNormal = parseInt(item.precio) || 0;
      _precioMayor  = parseInt(item.precio_mayor) || 0;

      // Aplicar precio según cantidad actual
      actualizarPrecioPorCantidad();

      var stockInfo  = document.getElementById("stock_info");
      var stockValue = document.getElementById("stock_value");
      if (stockInfo && stockValue) {
        stockValue.textContent = item.stock;
        stockInfo.classList.remove("hidden");
      }

      // Configurar descuento según producto
      configurarDescuento(item.descuento === true, item.descuento_maximo);
    }
  });
</script>
