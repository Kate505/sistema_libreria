<div class="flex justify-center items-center min-h-[calc(100vh-10rem)]">
  <div class="card bg-base-100 w-full max-w-md shrink-0 shadow-2xl border border-base-200">
    <div class="card-body">
      <% if (alert = flash[:alert]) %>
        <div role="alert" class="alert alert-error alert-soft mb-4" id="alert"><%= alert %></div>
      <% end %>

      <fieldset class="fieldset">
        <h2 class="text-2xl font-bold mb-2">Cambio de Contraseña Obligatorio</h2>
        <p class="text-sm text-base-content/70 mb-4">
          Por razones de seguridad, debes actualizar tu contraseña temporal antes de continuar utilizando el sistema.
        </p>

        <%= form_with model: Current.user, url: user_password_path, method: :patch, class: "contents", data: { turbo: false } do |f| %>
          <%= f.label :password, 'Nueva Contraseña', class: 'label' %>
          <%= f.password_field :password, class: 'input',
                               required: true, placeholder: 'Ingresa tu nueva contraseña', minlength: 6, maxlength: 72 %>

          <%= f.label :password_confirmation, 'Confirmar Nueva Contraseña', class: 'label mt-2' %>
          <%= f.password_field :password_confirmation, class: 'input',
                               required: true, placeholder: 'Repite la nueva contraseña', minlength: 6, maxlength: 72 %>

          <div class="mt-6 flex gap-2 w-full">
            <%= f.submit "Actualizar Contraseña", class: "btn btn-primary flex-1" %>
            <%= link_to "Salir", session_path, data: { turbo_method: :delete }, class: "btn btn-outline" %>
          </div>
        <% end %>
      </fieldset>
    </div>
  </div>
</div>
